# Bus Fleet Manager — Environment Variables
# Copy this file to .env.local and fill in your Supabase project values.

# Supabase project URL (e.g., https://yourproject.supabase.co or http://127.0.0.1:54321 for local)
VITE_SUPABASE_URL=http://127.0.0.1:54321

# Supabase anonymous (public) key — safe for frontend use
VITE_SUPABASE_ANON_KEY=your-anon-key-here
